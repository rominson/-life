{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's display name" },
        "phone": { "type": "string", "description": "User's phone number" },
        "birthDate": { "type": "string", "format": "date", "description": "User's birth date" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["phone"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A life goal or wish",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Goal content" },
        "age": { "type": "integer", "description": "Target age" },
        "completed": { "type": "boolean", "description": "Whether the goal is achieved" }
      },
      "required": ["title", "age"]
    },
    "Letter": {
      "title": "Letter",
      "description": "A letter to the future self",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "Letter content" },
        "unlockAge": { "type": "integer", "description": "Age when the letter unlocks" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the letter was written" }
      },
      "required": ["content", "unlockAge", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User's life goals"
    },
    "/users/{userId}/letters/{letterId}": {
      "schema": "Letter",
      "description": "User's future letters"
    }
  }
}
